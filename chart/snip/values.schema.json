{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Snip Helm chart values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of Snip app replicas"
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["repository", "tag"]
    },
    "baseURL": {
      "type": "string",
      "description": "Public base URL of the app, e.g. https://snip.example.com"
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": { "type": "integer" },
        "targetPort": { "type": "integer" }
      },
      "required": ["type", "port", "targetPort"]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "tls": { "type": "array" }
      },
      "required": ["enabled"]
    },
    "tls": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["auto", "manual", "selfsigned"]
        },
        "secretName": { "type": "string" },
        "issuerName": { "type": "string" }
      },
      "required": ["mode"]
    },
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    },
    "externalDatabase": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "name": { "type": "string" },
        "user": { "type": "string" },
        "password": { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    },
    "externalRedis": {
      "type": "object",
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer" },
        "password": { "type": "string" },
        "existingSecret": { "type": "string" }
      }
    },
    "smtp": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "port": { "type": "integer" }
      }
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "required": ["enabled"]
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "required": ["enabled"]
    },
    "replicated": {
      "type": "object",
      "description": "Replicated SDK subchart values"
    },
    "global": {
      "type": "object",
      "description": "Global values injected by the Replicated registry at install time",
      "properties": {
        "security": {
          "type": "object",
          "properties": {
            "allowInsecureImages": { "type": "boolean" }
          }
        },
        "replicated": {
          "type": "object",
          "properties": {
            "channelName":      { "type": "string" },
            "customerEmail":    { "type": "string" },
            "customerName":     { "type": "string" },
            "dockerconfigjson": { "type": "string" },
            "licenseID":        { "type": "string" },
            "licenseType":      { "type": "string" },
            "licenseFields":    { "type": "object" }
          }
        }
      }
    }
  },
  "required": ["image", "service"],
  "if": {
    "properties": {
      "postgresql": { "properties": { "enabled": { "const": false } } }
    }
  },
  "then": {
    "properties": {
      "externalDatabase": {
        "required": ["host", "name", "user"]
      }
    }
  }
}
